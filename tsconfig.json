{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Modules */
    "module": "ESNext",
    "rootDir": ".",
    "moduleResolution": "Bundler",
    "paths": {
      "@hwy-fm/*": ["./university/*"],
      "@hwy-fm/builder": ["./university/dynamic-builder"],
      "@hwy-fm/plugin": ["./university/dynamic-plugin"]
    },
    "typeRoots": [
      "node_modules/@types",
      "./typings/**/*"
    ],
    "resolveJsonModule": true,

    /* Emit */
    "declaration": true,
    "outDir": "dist",
    "importHelpers": true,

    /* Interop Constraints */
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "strict": false,
    "noImplicitAny": true,

    /* Completeness */
    "skipLibCheck": true
  },
  "include": [
    "gulpfile.ts",
    "script/**/*.ts",
    "university/**/*",
    "typings/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts"
  ],
  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
